{
  "name": "pi-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop workbench for pi-agent.",
  "author": "haohui <haohui-w@qq.com>",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "npm run build && electron-builder --publish never",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "out/main/main.js",
  "build": {
    "appId": "com.haohuiw.pi-ui",
    "productName": "Pi Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "zip"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    },
    "linux": {
      "target": ["AppImage", "tar.gz"],
      "category": "Development"
    }
  }
}
